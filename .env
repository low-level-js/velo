# Configuracion del servidor Velo
# Host en el que escucha el servidor TCP
HOST=127.0.0.1

# Puerto del servidor TCP
PORT=4444

# Maximo de conexiones simultaneas permitidas
MAX_CONNECTIONS=100

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# Numero de bases de datos disponibles (0 a DB_COUNT-1)
DB_COUNT=16

# Intervalo en milisegundos para el sweep de claves expiradas
SWEEP_INTERVAL_MS=1000
